# =============================================================================
# Vigilantia SIEM — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env real no repositório.
# =============================================================================

# ── JWT (compartilhado entre gateway e auth) ──────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=TROQUE_POR_SEGREDO_FORTE_AQUI
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── API Key para ingestão via Filebeat (RF01) ─────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(24))"
INGEST_API_KEY=TROQUE_POR_API_KEY_FORTE_AQUI

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USER=elastic
# Gere com: python -c "import secrets; print(secrets.token_hex(16))"
ELASTICSEARCH_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI

# ── PostgreSQL (RF06 — usuários persistidos) ──────────────────────────────────
POSTGRES_USER=vigilantia
POSTGRES_PASSWORD=TROQUE_POR_SENHA_POSTGRES
POSTGRES_DB=vigilantia
DATABASE_URL=postgresql+asyncpg://vigilantia:TROQUE_POR_SENHA_POSTGRES@postgres:5432/vigilantia

# ── Credenciais padrão dos usuários seed (criados na primeira inicialização) ──
ADMIN_DEFAULT_PASSWORD=TROQUE_POR_SENHA_ADMIN
CLIENT_DEFAULT_PASSWORD=TROQUE_POR_SENHA_CLIENTE

# ── URLs internas dos serviços (usadas pelo gateway) ─────────────────────────
AUTH_SERVICE_URL=http://auth:8001
PARSER_SERVICE_URL=http://parser:8002

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL do gateway acessível pelo navegador do usuário final
VITE_GATEWAY_URL=http://localhost:8000

# ── Email (RF08 — habilitado na Phase 3) ─────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASSWORD=TROQUE_POR_SENHA_SMTP
ALERT_EMAIL_FROM=alerts@vigilantia.local
ALERT_EMAIL_TO=admin@vigilantia.local
